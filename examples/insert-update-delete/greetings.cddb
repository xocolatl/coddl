database greetings;

base relvar Greetings {
    id: Integer,
    message: Text,
}
key { id };

// Tuples slated for removal — same heading as Greetings, so it can be
// subtracted from it.
base relvar Stale {
    id: Integer,
    message: Text,
}
key { id };

// Tuples to add — same heading again, so it can be unioned into Greetings.
base relvar NewArrivals {
    id: Integer,
    message: Text,
}
key { id };
