program hello_world;

oper to_text { self: Sequence Text } -> Text [
    if self.cardinality {} = 0 then [
        "no one"
    ] else [
        self [0] || " and possibly others"
    ]
];

oper main {} [
    let names = Sequence ["Andy", "Alice", "Bob"];
    let message = format { template: f"Hello, {names}!", params: { names } };
    write_line { message };
];
