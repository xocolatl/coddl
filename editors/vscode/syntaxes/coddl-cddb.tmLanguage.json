{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Coddl Catalog",
    "scopeName": "source.coddl.cddb",
    "fileTypes": ["cddb"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.coddl", "match": "//.*$" },
                { "include": "#block_comment" }
            ]
        },
        "block_comment": {
            "name": "comment.block.coddl",
            "begin": "/\\*",
            "end": "\\*/",
            "patterns": [{ "include": "#block_comment" }]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.coddl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.coddl", "match": "\\\\." }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.coddl",
                    "match": "\\b([0-9][0-9_]*)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.declaration.coddl",
                    "match": "\\b(database|relvar|type|possrep|constraint|key)\\b"
                },
                {
                    "name": "storage.modifier.coddl",
                    "match": "\\b(base|virtual)\\b"
                },
                {
                    "name": "keyword.other.relational.coddl",
                    "match": "\\b(where|project|replace|rename|join|union|intersect|minus|extend|summarize)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.builtin.coddl",
                    "match": "\\b(Integer|Rational|Approximate|Text|Character|Binary|Byte|Boolean)\\b"
                },
                {
                    "name": "support.type.generator.coddl",
                    "match": "\\b(Tuple|Relation|Sequence)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.coddl",
                    "match": "="
                },
                {
                    "name": "punctuation.separator.coddl",
                    "match": "[,;:]"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.parameter.named-arg.coddl",
                    "match": "(?<=[\\{,]\\s*)([A-Za-z_][A-Za-z0-9_#]*)\\s*(?=:)"
                },
                {
                    "name": "entity.name.type.coddl",
                    "match": "\\b[A-Z][A-Za-z0-9_]*[#]?\\b"
                },
                {
                    "name": "variable.other.coddl",
                    "match": "\\b[a-z_][A-Za-z0-9_#]*\\b"
                }
            ]
        }
    }
}
