{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Coddl",
    "scopeName": "source.coddl",
    "fileTypes": ["cd"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#format_strings" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.coddl",
                    "match": "//.*$"
                },
                {
                    "include": "#block_comment"
                }
            ]
        },
        "block_comment": {
            "name": "comment.block.coddl",
            "begin": "/\\*",
            "end": "\\*/",
            "patterns": [
                {
                    "include": "#block_comment"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.coddl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.coddl",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "format_strings": {
            "patterns": [
                {
                    "comment": "Format-string literal f\"…\" — the `f` is fused to the opening quote (lexed as one token), so it's coloured as part of the string, not as an identifier. The negative lookbehind keeps `xf\"` (identifier `xf` + plain string) and `f \"` (with a space) out.",
                    "name": "string.quoted.double.format.coddl",
                    "begin": "(?<![A-Za-z0-9_#])f\"",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.coddl" }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.coddl" }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.coddl",
                            "match": "\\\\."
                        },
                        {
                            "comment": "Escaped literal braces {{ and }}.",
                            "name": "constant.character.escape.coddl",
                            "match": "\\{\\{|\\}\\}"
                        },
                        {
                            "comment": "{name} placeholder — an attribute of the params tuple.",
                            "match": "(\\{)([A-Za-z_][A-Za-z0-9_]*)(\\})",
                            "captures": {
                                "1": { "name": "punctuation.section.interpolation.begin.coddl" },
                                "2": { "name": "variable.other.interpolation.coddl" },
                                "3": { "name": "punctuation.section.interpolation.end.coddl" }
                            }
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.approximate.coddl",
                    "match": "\\b([0-9][0-9_]*(\\.[0-9][0-9_]*)?[eE][+-]?[0-9][0-9_]*)\\b"
                },
                {
                    "name": "constant.numeric.rational.coddl",
                    "match": "\\b([0-9][0-9_]*\\.[0-9][0-9_]*)\\b"
                },
                {
                    "name": "constant.numeric.integer.coddl",
                    "match": "\\b(0[xX][0-9a-fA-F][0-9a-fA-F_]*|0[bB][01][01_]*|0[oO][0-7][0-7_]*|0[dD][0-9][0-9_]*|[0-9][0-9_]*)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.coddl",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.relation.coddl",
                    "match": "\\b(reltrue|relfalse)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.declaration.coddl",
                    "match": "\\b(program|database|oper|relvar|type|possrep|constraint|var|key)\\b"
                },
                {
                    "name": "keyword.declaration.binding.coddl",
                    "match": "\\b(let|mut)\\b"
                },
                {
                    "name": "storage.modifier.coddl",
                    "match": "\\b(real|base|virtual|private|public)\\b"
                },
                {
                    "name": "keyword.control.coddl",
                    "match": "\\b(if|then|else|end|do|to|return)\\b"
                },
                {
                    "name": "keyword.other.iteration.coddl",
                    "match": "\\b(load|array|from|order|asc|desc|by)\\b"
                },
                {
                    "comment": "Infix relational operators (join/times/compose/intersect/union/minus/matching/where/when/otherwise — `not matching` gets `not` from the logical group), the postfix pipeline suffixes (project/replace/extend/rename/wrap/unwrap/tclose), prefix `extract`, and the designed-but-unbuilt sugar (summarize/group/ungroup).",
                    "name": "keyword.other.relational.coddl",
                    "match": "\\b(join|times|compose|union|intersect|minus|matching|where|when|otherwise|extract|extend|summarize|replace|rename|project|group|ungroup|wrap|unwrap|tclose)\\b"
                },
                {
                    "comment": "Unicode operator glyph synonyms (grammar.md § Unicode operator glyphs): ⋈ join, ∪ union, ∩ intersect, ∖ minus, ⋉ matching, ▷ not-matching, ¬ not. Lexed as IDENTs, so no \\b anchors (word boundaries misfire next to symbols).",
                    "name": "keyword.other.relational.coddl",
                    "match": "⋈|∪|∩|∖|⋉|▷|¬"
                },
                {
                    "comment": "`all but` projection-away, matched as a pair so a lone identifier named `all` or `but` (e.g. inside the brace list) stays uncolored",
                    "name": "keyword.other.relational.coddl",
                    "match": "\\ball\\s+but\\b"
                },
                {
                    "comment": "DML statement verbs — sugar for relational assignment (truncate R; delete R where p; insert R …; update R …). Contextual keywords (statement-leading only), coloured unconditionally like the relational keywords above.",
                    "name": "keyword.other.dml.coddl",
                    "match": "\\b(insert|update|delete|truncate)\\b"
                },
                {
                    "name": "keyword.operator.logical.coddl",
                    "match": "\\b(and|or|not)\\b"
                },
                {
                    "comment": "Textual arithmetic: `div` (truncating integer division) and the designed `mod`.",
                    "name": "keyword.operator.arithmetic.coddl",
                    "match": "\\b(div|mod)\\b"
                },
                {
                    "name": "keyword.other.transaction.coddl",
                    "match": "\\b(begin|commit|rollback|transaction|savepoint)\\b"
                },
                {
                    "name": "keyword.other.coddl",
                    "match": "\\b(with|as|add|the)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.builtin.coddl",
                    "match": "\\b(Integer|Rational|Approximate|Text|Character|Binary|Byte|Boolean)\\b"
                },
                {
                    "name": "support.type.generator.coddl",
                    "match": "\\b(Tuple|Relation|Sequence)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.coddl",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.coddl",
                    "match": "<>|<=|>=|<|>|="
                },
                {
                    "name": "keyword.operator.arithmetic.coddl",
                    "match": "\\+|-|\\*|/"
                },
                {
                    "name": "punctuation.separator.coddl",
                    "match": "[,;:]"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.function.coddl",
                    "match": "\\b([a-z_][A-Za-z0-9_#]*)(?=\\s*\\{)"
                },
                {
                    "name": "variable.parameter.named-arg.coddl",
                    "match": "(?<=[\\{,]\\s*)([A-Za-z_][A-Za-z0-9_#]*)\\s*(?=:)"
                },
                {
                    "name": "entity.name.type.coddl",
                    "match": "\\b[A-Z][A-Za-z0-9_]*[#]?\\b"
                },
                {
                    "name": "variable.other.coddl",
                    "match": "\\b[a-z_][A-Za-z0-9_#]*\\b"
                }
            ]
        }
    }
}
